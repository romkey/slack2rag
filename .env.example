# ── Docker image (optional) ───────────────────────────────────────────────────
# When set, docker compose pulls this image instead of building from source.
# IMAGE=ghcr.io/<owner>/slack2rag:latest

# ── Required ──────────────────────────────────────────────────────────────────
# Bot token from https://api.slack.com/apps — needs scopes:
#   channels:read  channels:history  users:read
SLACK_BOT_TOKEN=xoxb-your-token-here

# ── Slack ─────────────────────────────────────────────────────────────────────
# Comma-separated channel names or IDs to index.
# Leave empty to index ALL public channels visible to the bot.
SLACK_CHANNELS=

# ── Qdrant ────────────────────────────────────────────────────────────────────
# Overridden to http://qdrant:6333 inside docker-compose; set for external use.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=slack_messages

# ── Ollama embeddings ─────────────────────────────────────────────────────────
# URL of the Ollama server.  Overridden to http://ollama:11434 inside
# docker-compose; set for external use.
OLLAMA_URL=http://localhost:11434

# Any Ollama model that supports embeddings.  Pull it first:
#   ollama pull nomic-embed-text
# Popular choices:
#   nomic-embed-text    — 768d, strong general-purpose (recommended)
#   mxbai-embed-large   — 1024d, high quality
#   all-minilm          — 384d, lightweight
# NOTE: Changing models requires deleting the Qdrant collection and re-indexing.
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── Retrieval quality ─────────────────────────────────────────────────────────

# Minimum cosine similarity score (0.0–1.0) for search results.
# Results below this threshold are discarded, letting the chatbot say
# "I don't know" instead of hallucinating from weak matches.
# 0.0 disables the threshold.
SCORE_THRESHOLD=0.0

# Enable hybrid search: stores sparse (BM25-like) vectors alongside
# dense embeddings and fuses them with Reciprocal Rank Fusion.
# Catches keyword/exact-match queries that pure semantic search misses.
# NOTE: Enabling requires deleting the Qdrant collection and re-indexing.
HYBRID_SEARCH=false

# ── Reaction boost ─────────────────────────────────────────────────────

# Messages with at least this many emoji reactions get "[highlighted by
# team]" prepended before embedding, making community-curated content
# cluster together in vector space and rank higher.  0 disables the boost.
REACTION_BOOST_THRESHOLD=3

# ── Message filtering ─────────────────────────────────────────────────────────

# Minimum character length for standalone messages (no replies) to be
# indexed.  Shorter messages ("ok", "thanks", "+1") are skipped.
# Threads are always indexed regardless of length.  0 disables filtering.
MIN_MESSAGE_LENGTH=20

# ── Thread updates ────────────────────────────────────────────────────────────

# Hours to look back for threads that gained new replies since they
# were last indexed.  This refresh pass runs after each incremental
# sync.  0 disables thread refresh.  24–72 is a good starting value.
THREAD_UPDATE_LOOKBACK_HOURS=0

# ── Sync ──────────────────────────────────────────────────────────────────────
# Minutes between syncs (only relevant when not running one-shot).
SYNC_INTERVAL_MINUTES=60

# Set to "true" to run once and exit (useful for cron / k8s jobs).
RUN_ONCE=false

# How many messages to embed per batch (tune for memory vs. speed).
BATCH_SIZE=50

# Seconds to pause between Slack API calls.  1.2 s keeps well under
# the free-plan rate limit (~50 req/min).  Set to 0 for paid plans.
SLACK_API_PAUSE=1.2
